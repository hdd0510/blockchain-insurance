PORT=3001

# --- MySQL ---
DB_HOST=localhost
DB_NAME=insurance_db
DB_USER=root
DB_PASS=password

# --- Auth ---
JWT_SECRET=supersecretkey123

# --- Chain RPC ---
RPC_URL=http://127.0.0.1:8545

# --- Contract addresses (auto-filled by scripts/start-all.sh) ---
CONTRACT_ADDRESS_POLICY=
CONTRACT_ADDRESS_CLAIMS=
CONTRACT_ADDRESS_ORACLE=
CONTRACT_ADDRESS_HOSPITAL=

# --- Admin wallets (multi-sig) ---
ADMIN_WALLET=
# Primary admin signer private key (used by backend for onlyAdmin calls).
PRIVATE_KEY=
# OPTIONAL: a second admin signer so multi-sig can complete from a single
# backend call (set use_secondary_signer=true on /sign or /review endpoints).
PRIVATE_KEY_SIGNER_B=

# --- Oracle node (Section 2.2) ---
# Private key for the address that runs MockOracle.fulfillVerification.
# Only this key can fulfill verifications on-chain.
ORACLE_NODE_PRIVATE_KEY=
# Backfill events from this block on startup (optional). Empty = future only.
ORACLE_POLL_FROM_BLOCK=

# --- Hospital API (off-chain DB lookup) ---
# External hospital service endpoint used for record lookup.
HOSPITAL_API_BASE=http://localhost:3002/api/hospital
# Shared secret for the oracle -> hospital API call. Optional.
HOSPITAL_API_TOKEN=

# Run the oracle daemon inside the backend process (default true). Set
# false if running scripts/start-all.sh which starts it as a separate process.
START_ORACLE_INPROCESS=true
